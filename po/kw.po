#: gnome-initial-setup/pages/account/um-realm-manager.c:795
#, c-format
msgid "Cannot log in as %s at the %s domain"
msgstr "Ny yllir omgelmi avel %s y'n arlotteth %s"

#: gnome-initial-setup/pages/account/um-realm-manager.c:787
msgid "Invalid password, please try again"
msgstr "Ger-tremena anewn, assayewgh arta mar pleg"

#: gnome-initial-setup/pages/account/um-realm-manager.c:800
#, c-format
msgid "Couldn’t connect to the %s domain: %s"
msgstr "Ny yllri junya dhe'n arlotteth %s: %s"

#: gnome-initial-setup/pages/account/um-utils.c:145
msgid "Sorry, that user name isn’t available. Please try another."
msgstr ""
"Soweth, an hanow devnydhyer nag yw kavadow. Assayewgh neppyth aral mar pleg."

#: gnome-initial-setup/pages/account/um-utils.c:148
#, c-format
msgid "The username is too long."
msgstr "Re hir yw an hanow devnydhyer."

#: gnome-initial-setup/pages/account/um-utils.c:151
msgid "The username must start with a lower case letter from a-z."
msgstr ""
"Res yw dhe'n hanow devnydhyer dalleth gans lytheren vyghan dhyworth a-z."

#: gnome-initial-setup/pages/account/um-utils.c:154
msgid "That username isn’t available. Please try another."
msgstr ""
"An hanow devnydhyer na nag yw kavadow. Assayewgh neppyth aral mar pleg."

#: gnome-initial-setup/pages/account/um-utils.c:157
msgid ""
"The username should only consist of lower case letters from a-z, digits, and "
"the following characters: - _"
msgstr ""
"An hanow devnydhyer a kodh synsi lytherennow byghan dhyworth a-z, niverow, "
"ha'n lytherennow a sew: - _"

#: gnome-initial-setup/pages/account/um-utils.c:161
msgid "This will be used to name your home folder and can’t be changed."
msgstr ""
"Hemm a vydh devnydhys rag henwel agas restrenva dre ha ny yllir bos chanjys."

