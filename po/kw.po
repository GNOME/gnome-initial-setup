msgstr "A-dro Dhywgh"

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:64
msgid "Please provide a name and username. You can choose a picture too."
msgstr ""
"Proviewgh hanow ha ger-tremena mar pleg. Hwi a yll dewis skeusennik ynwedh."

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:74
msgid "_Full Name"
msgstr "Hanow _Leun"

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:121
msgid "Set up _parental controls for this user"
msgstr "Selya routyans _kerensel rag an devnydhyer ma"

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:122
msgid "For use by a parent or supervisor, who must set up their own password."
msgstr "Rag devnydh gans kar po gorwolyas, neb a selya ger-tremena aga honan."

#: gnome-initial-setup/pages/account/gis-account-page.ui:32
msgid "_Enterprise Login"
msgstr "Omgelmans _Negysieth"

#: gnome-initial-setup/pages/account/gis-account-page.ui:41
msgid "Go online to set up Enterprise Login."
msgstr "Kewgh warlinen rag selya Omgelmans Negysieth."

#: gnome-initial-setup/pages/account/um-realm-manager.c:310
msgid "Cannot automatically join this type of domain"
msgstr "Ny yllir omjunya an eghen ma a arlotteth yn awtomatek"

#: gnome-initial-setup/pages/account/um-realm-manager.c:373
#, c-format
msgid "No such domain or realm found"
msgstr "Nyns eus arlotteth po gwlaskor a'n par na"

