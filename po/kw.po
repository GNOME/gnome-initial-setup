msgstr "Yma edhom dhyn nebes manylyon rag kowlwul selyans."

#: gnome-initial-setup/pages/account/gis-account-page-local.c:476
msgid "Administrator"
msgstr "Menystrer"

#: gnome-initial-setup/pages/account/gis-account-page-local.c:482
