msgid "Other…"
msgstr "Aral…"

#: gnome-initial-setup/pages/network/gis-network-page.c:401
msgid "Wireless networking is disabled"
msgstr "Rosweythans diwiver yw marow"

#: gnome-initial-setup/pages/network/gis-network-page.c:408
msgid "Checking for available wireless networks"
msgstr "Ow checkya rag rosweythyow diwiver kavadow"

#: gnome-initial-setup/pages/network/gis-network-page.c:809
msgid "Network"
msgstr "Rosweyth"

#: gnome-initial-setup/pages/network/gis-network-page.ui:15
msgid "Wi-Fi"
msgstr "DiWi"

#: gnome-initial-setup/pages/network/gis-network-page.ui:16
msgid ""
"Connecting to the internet helps you get new apps, information, and other "
"upgrades. It also helps set the time and your location automatically."
msgstr ""
"Ow junya dhe'n kesrosweyth gweres gans ow kavos appys nowydh, kedhlow, ha "
"gwellheansow aral, maga ta settya an termyn ha dha tyller yn awtomatek."

#: gnome-initial-setup/pages/network/gis-network-page.ui:57
msgid "No wireless available"
msgstr "Diwiver kavadow vyth"

#: gnome-initial-setup/pages/network/gis-network-page.ui:70
msgid "Turn On"
msgstr "Bywhe"

#. Translators: The placeholder is the user’s full name.
#: gnome-initial-setup/pages/parental-controls/gis-parental-controls-page.c:106
#, c-format
msgid "Parental Controls for %s"
msgstr "Routyansow Kerensel rag %s"

#: gnome-initial-setup/pages/parental-controls/gis-parental-controls-page.c:108
msgid "Set restrictions on what this user can run or install."
msgstr "Settya fronansow war byth an devnydhyer ma a yll eksekutya po lea."

#: gnome-initial-setup/pages/parental-controls/gis-parental-controls-page.c:215
msgid "Parental Controls"
msgstr "Routyansow Kerensel"

#. Translators: The placeholder is for the user’s full name.
#: gnome-initial-setup/pages/password/gis-password-page.c:92
#, c-format
msgid "Set a Password for %s"
msgstr "Dewis Ger-Tremena rag %s"

#: gnome-initial-setup/pages/password/gis-password-page.c:94
msgid "Be careful not to lose your password."
msgstr "Bedhewgh prederus rag na kelli dha ger-tremena."

#: gnome-initial-setup/pages/password/gis-password-page.c:99
msgid "Set a Parent Password"
msgstr "Dewis Ger-Tremena Kar"

#. Translators: The placeholder is the full name of the child user on the system.
#: gnome-initial-setup/pages/password/gis-password-page.c:101
#, c-format
msgid "This password will control access to the parental controls for %s."
msgstr "An ger-tremena ma a wra routya hedhas dhe'n routyans kerensel rag %s."

#: gnome-initial-setup/pages/password/gis-password-page.c:223
#, c-format
msgid "Password strength: %s."
msgstr "Krefter ger-tremena: %s."

#: gnome-initial-setup/pages/password/gis-password-page.c:249
#: gnome-initial-setup/pages/password/gis-password-page.c:251
msgid "The passwords do not match."
msgstr "An geryow-tremena na desedha."

#: gnome-initial-setup/pages/password/gis-password-page.c:430
msgid "Password"
msgstr "Ger-Tremena"

#: gnome-initial-setup/pages/password/gis-password-page.ui:68
msgid "_Confirm Password"
msgstr "_Afydhya Ger-Tremena"

#: gnome-initial-setup/pages/password/gis-password-page.ui:92
msgid "Password _Hint"
msgstr "_Hynt Ger-Tremena"

#: gnome-initial-setup/pages/password/gis-password-page.ui:103
msgid "Password hint will be shown in case you forget your password."
msgstr "Hynt ger-tremena a wra bos diskwedhys mar ty ankevi dha ger-tremena."

#: gnome-initial-setup/pages/password/pw-utils.c:81
msgctxt "Password hint"
msgid "The new password needs to be different from the old one."
msgstr "Yma edhom dhe’n ger-tremena nowydh bos dihaval dhyworth an re koth."

#: gnome-initial-setup/pages/password/pw-utils.c:83
msgctxt "Password hint"
msgid ""
"This password is very similar to your last one. Try changing some letters "
"and numbers."
msgstr ""
"An ger-tremena ma yw pur haval dhe'n re kyns. Assaya ow chanjya nebes "
"lytherennow ha niverow."

#: gnome-initial-setup/pages/password/pw-utils.c:85
#: gnome-initial-setup/pages/password/pw-utils.c:93
msgctxt "Password hint"
msgid ""
"This password is very similar to your last one. Try changing the password a "
"bit more."
msgstr ""
"An ger-tremena ma yw pur haval dhe'n re kyns. Assaya ow chanjya an ger-"
"tremena nebes moy."

#: gnome-initial-setup/pages/password/pw-utils.c:87
msgctxt "Password hint"
msgid ""
"This is a weak password. A password without your user name would be stronger."
msgstr ""
"Ger-tremena gwann yw hemma. Ger-tremena heb ow synsi dha hanow devnydhyer a "
"via kreva."

#: gnome-initial-setup/pages/password/pw-utils.c:89
msgctxt "Password hint"
msgid "This is a weak password. Try to avoid using your name in the password."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag avodya ow devnydhya dha hanow y'n "
"ger-tremena."

#: gnome-initial-setup/pages/password/pw-utils.c:91
msgctxt "Password hint"
msgid ""
"This is a weak password. Try to avoid some of the words included in the "
"password."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag avodya neb a'n eryow synsys y'n "
"ger-tremena."

#: gnome-initial-setup/pages/password/pw-utils.c:95
msgctxt "Password hint"
msgid "This is a weak password. Try to avoid common words."
msgstr "Ger-tremena gwann yw hemma. Assayewgh rag avodya geryow kemmyn."

#: gnome-initial-setup/pages/password/pw-utils.c:97
msgctxt "Password hint"
msgid "This is a weak password. Try to avoid reordering existing words."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag avodya ow dasaraya geryow ena "
"seulabrys."

#: gnome-initial-setup/pages/password/pw-utils.c:99
msgctxt "Password hint"
msgid "This is a weak password. Try to use more numbers."
msgstr "Ger-tremena gwann yw hemma. Assayewgh rag devnydhya moy niverow."

#: gnome-initial-setup/pages/password/pw-utils.c:101
msgctxt "Password hint"
msgid "This is a weak password. Try to use more uppercase letters."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag devnydhya moy lytherennow bras."

#: gnome-initial-setup/pages/password/pw-utils.c:103
msgctxt "Password hint"
msgid "This is a weak password. Try to use more lowercase letters."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag devnydhya moy lytherennow byghan."

#: gnome-initial-setup/pages/password/pw-utils.c:105
msgctxt "Password hint"
msgid ""
"This is a weak password. Try to use more special characters, like "
"punctuation."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag devnydhya moy lytherennow "
"arbennik, kepar ha poyntyans."

#: gnome-initial-setup/pages/password/pw-utils.c:107
msgctxt "Password hint"
msgid ""
"This is a weak password. Try to use a mixture of letters, numbers and "
"punctuation."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag devnydhya kemyskans a lytherennow, "
"niverow ha poyntyans."

#: gnome-initial-setup/pages/password/pw-utils.c:109
msgctxt "Password hint"
msgid "This is a weak password. Try to avoid repeating the same character."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag avodya ow dasleverel an lytheren "
"keth."

#: gnome-initial-setup/pages/password/pw-utils.c:111
msgctxt "Password hint"
msgid ""
"This is a weak password. Try to avoid repeating the same type of character: "
"you need to mix up letters, numbers and punctuation."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag avodya ow dasleverel an eghen keth "
"a lytheren: res yw dhywgh kaboli lytherennow, niverow ha poyntyans."

#: gnome-initial-setup/pages/password/pw-utils.c:113
msgctxt "Password hint"
msgid "This is a weak password. Try to avoid sequences like 1234 or abcd."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag avodya holyansow kepar ha 1234 po "
"abcd."

#: gnome-initial-setup/pages/password/pw-utils.c:115
msgctxt "Password hint"
msgid ""
"This is a weak password. Try to add more letters, numbers and punctuation."
msgstr ""
"Ger-tremena gwann yw hemma. Assayewgh rag addya moy lytherennow, niverow ha "
"poyntyans."

#: gnome-initial-setup/pages/password/pw-utils.c:117
msgctxt "Password hint"
msgid "Mix uppercase and lowercase and try to use a number or two."
msgstr ""
"Kemyskewgh kas bras ha byghan hag assayewgh rag devnydhya nebes niverow."

#: gnome-initial-setup/pages/password/pw-utils.c:119
msgctxt "Password hint"
msgid ""
"Adding more letters, numbers and punctuation will make the password stronger."
msgstr ""
"Owth addya moy lytherennow, niverow ha poyntyans a wra krefhe an ger-tremena."

#. TRANSLATORS: this string describes a password as being poor
#: gnome-initial-setup/pages/password/pw-utils.c:146
msgid "poor"
msgstr "drog"

#. TRANSLATORS: this string describes a password as being weak
#: gnome-initial-setup/pages/password/pw-utils.c:150
msgid "weak"
msgstr "gwann"

#. TRANSLATORS: this string describes a password as being strong
#: gnome-initial-setup/pages/password/pw-utils.c:154
#: gnome-initial-setup/pages/password/pw-utils.c:157
msgid "strong"
msgstr "krev"

#. TRANSLATORS: this string describes a password as being excellent
#: gnome-initial-setup/pages/password/pw-utils.c:161
msgid "excellent"
msgstr "bryntin"

#. Translators: the first parameter here is the name of a distribution,
#. * like "Fedora" or "Ubuntu".
#.
#: gnome-initial-setup/pages/privacy/gis-privacy-page.c:70
#, c-format
msgid ""
"Sends technical reports that do not contain personal information. Data is "
"collected by %1$s (<a href='%2$s'>privacy policy</a>)."
msgstr ""
"Y tanvon derivasow teknogel na synsi kedhlow privedh. Data yw kuntellys gans "
"%1$s (<a href='%2$s'>polici privetter</a>)."

#. Translators: the parameter here is the name of a distribution,
#. * like "Fedora" or "Ubuntu".
#.
#: gnome-initial-setup/pages/privacy/gis-privacy-page.c:82
#, c-format
msgid ""
"Sends technical reports that do not contain personal information. Data is "
"collected by %s."
msgstr ""
"Y tanvon derivasow na synsi kedhlow privedh. Data yw kuntellys gans %s."

#: gnome-initial-setup/pages/privacy/gis-privacy-page.c:125
msgid "Allows apps to determine your geographical location."
msgstr "Y asa appys rag determya dha tyller doroniethel."

#: gnome-initial-setup/pages/privacy/gis-privacy-page.c:171
#: gnome-initial-setup/pages/privacy/gis-privacy-page.ui:15
msgid "Privacy"
msgstr "Privetter"

#: gnome-initial-setup/pages/privacy/gis-privacy-page.ui:33
msgid "Location Services"
msgstr "Gonisyow Tyller"

#: gnome-initial-setup/pages/privacy/gis-privacy-page.ui:65
msgid "Automatic Problem Reporting"
msgstr "Derivasow Kudyn Awtomatek"

#: gnome-initial-setup/pages/privacy/gis-privacy-page.ui:97
msgid "Privacy controls can be changed at any time from the Settings app."
msgstr "Routyansow privetter a yll bos chanjys yn neb eur y'n app Settyansow."

#: gnome-initial-setup/pages/software/gis-software-page.c:127
#: gnome-initial-setup/pages/software/gis-software-page.ui:11
msgid "Third-Party Repositories"
msgstr "Repositoris Parti-Tressa"

#: gnome-initial-setup/pages/software/gis-software-page.c:129
#, c-format
msgid ""
"Third-party repositories provide access to additional software from selected "
"<a href='%s'>external sources</a>, including popular apps and drivers that "
"are important for some devices. Some proprietary software is included."
msgstr ""
