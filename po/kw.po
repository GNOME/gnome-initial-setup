msgstr "Chanjya Imach"

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:46
msgid "Remove Avatar"
msgstr "Remova Imach"

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:64
#: gnome-initial-setup/pages/account/gis-account-page.c:274
msgid "About You"
msgstr "A-dro Dhywgh"

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:65
msgid "Please provide a name and username. You can choose a picture too."
msgstr "Mar pleg provia hanow ha ger-tremena. Ty a yll dewis skeusen ynwedh."

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:81
msgid "_Full Name"
msgstr "Hanow _Leun"

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:159
msgid "Set up _parental controls for this user"
msgstr "Selya routyans _kerensel rag an devnydhyer ma"

#: gnome-initial-setup/pages/account/gis-account-page-local.ui:165
msgid "For use by a parent or supervisor, who must set up their own password."
msgstr "Rag devnydh gans kar po gorwolyas, neb a selya aga honan ger-tremena."

#: gnome-initial-setup/pages/account/gis-account-page.ui:32
msgid "_Enterprise Login"
msgstr "Omgelmans _Negysieth"

#: gnome-initial-setup/pages/account/gis-account-page.ui:41
msgid "Go online to set up Enterprise Login."
msgstr "Mos warlinen rag selya Omgelmans Negysieth."

#: gnome-initial-setup/pages/account/um-realm-manager.c:310
msgid "Cannot automatically join this type of domain"
msgstr "Ny yllir omjunya an eghen ma a arlotteth yn awtomatek"

#: gnome-initial-setup/pages/account/um-realm-manager.c:373
#, c-format
msgid "No such domain or realm found"
msgstr "Nyns eus arlotteth po gwlaskor a'n par ma"

#: gnome-initial-setup/pages/account/um-realm-manager.c:782
#: gnome-initial-setup/pages/account/um-realm-manager.c:796
#, c-format
msgid "Cannot log in as %s at the %s domain"
msgstr "Ny yllir omgelmi avel %s y'n arlotteth %s"

#: gnome-initial-setup/pages/account/um-realm-manager.c:788
msgid "Invalid password, please try again"
msgstr "Ger-tremena drog, assaya arta mar pleg"

#: gnome-initial-setup/pages/account/um-realm-manager.c:801
#, c-format
msgid "Couldn’t connect to the %s domain: %s"
msgstr "Ny yllri junya dhe'n arlotteth %s: %s"

#: gnome-initial-setup/pages/account/um-utils.c:153
msgid "Sorry, that user name isn’t available. Please try another."
msgstr ""
"Drog yw genev, nyns yw an hanow devnydhyer kavadow. Assaya aral mar pleg."

#: gnome-initial-setup/pages/account/um-utils.c:156
#, c-format
msgid "The username is too long."
msgstr "Re hir yw an hanow devnydhyer."

#: gnome-initial-setup/pages/account/um-utils.c:159
msgid "The username must start with a lower case letter from a-z."
msgstr "Y tal dhe hanow devnydhyer dalleth gans lytheren byghan dhyworth a-z."

#: gnome-initial-setup/pages/account/um-utils.c:162
msgid "That username isn’t available. Please try another."
msgstr "Nyns yw an hanow devnydhyer na kavadow. Assaya aral mar pleg."

#: gnome-initial-setup/pages/account/um-utils.c:165
msgid ""
"The username should only consist of lower case letters from a-z, digits, and "
"the following characters: - _"
msgstr ""
"An hanow devnydhyer y kodh synsi lytherennow byghan dhyworth a-z, niverow, "
"ha'n lytherennow a sew: - _"

#: gnome-initial-setup/pages/account/um-utils.c:169
msgid "This will be used to name your home folder and can’t be changed."
msgstr ""
"Bos devnydhys a wra hemma rag henwel dha restrenva tre ha ny yllir bos "
"chanjys."

